{
  "include": ["src", "tests"],
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    // Need to include `jest` in global typedefs for Jest itself to typecheck
    "types": ["jest"],

    "noEmit": true,

    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,

    // TODO: Enable these and fix errors
    "exactOptionalPropertyTypes": false,
    "noImplicitAny": false, // default true
    "noUncheckedIndexedAccess": false,
    "noUncheckedSideEffectImports": false,
    "verbatimModuleSyntax": false,

    "baseUrl": ".",
    "paths": {
      "CSS/*": ["css/*"],
      "Components/*": ["src/components/*"],
      "Context/*": ["src/context/*"],
      "Hooks/*": ["src/hooks/*"],
      "Images/*": ["images/*"],
      "Util/*": ["src/util/*"]
    }
  }
}
